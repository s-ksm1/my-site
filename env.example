# Copy to .env and adjust (do not commit .env with secrets).

# Required for production: long random string
JWT_SECRET=change_this_to_a_long_random_secret

# Optional: feedback email (defaults to bumblebee.autobot.bee@gmail.com in code)
# FEEDBACK_TO=you@example.com

# Optional: send feedback copies to your inbox via Gmail (or other SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=youraccount@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="My Second Brain <youraccount@gmail.com>"

# Optional: encrypt server/data.json at rest (requires matching key on every run)
# APP_ENCRYPTION_KEY=

# Optional: behind reverse proxy (Render, etc.)
# TRUST_PROXY=true
